// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url       = env("DATABASE_URL")
}

model Pacientes {
  id                Int      @id @default(autoincrement())
  nome              String
  status            Boolean
  cpf               String   @unique
  rg                String
  nascimento        DateTime
  profissao         String
  dataCadastro      DateTime @default(now())
  tipoCancer        String
  CIDprincipal      String
  CIDsecundario     String
  rua               String
  numero            String
  cep               String
  bairro            String
  cidade            String
  telefone1         String
  telefone2         String
}

model Emprestimo {
  id                Int      @id @default(autoincrement())
  nome              String
  cpf               String
  rg                String
  nascimento        DateTime
  dataEmprestimo    DateTime @default(now())
  materiaisEmprestados String
  rua               String
  numero            String
  cep               String
  bairro            String
  cidade            String
  telefone1         String
  telefone2         String
}

model Servicos {
  id                Int      @id @default(autoincrement())
  nome              String
  cpf               String
  tipoServico       String
  duracao           String
  valorServico      Float
  unidade           String
  tempoServico      String
}

model Funcionarios {
  id         Int      @id @default(autoincrement())
  nome              String
  email               String      @unique
  cargo       String
  telefone           String
}